<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginBottom="15dp"
    >

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_review_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@drawable/bg_my_review_card"
        android:padding="16dp"
        >

        <!--별점-->
        <RatingBar
            android:id="@+id/rating_bar"
            style="@style/CustomRatingBar12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:stepSize="0.5"
            android:rating="0"
            android:isIndicator="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            />

        <!--날짜-->
        <TextView
            android:id="@+id/tv_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="nnnn.nn.nn"
            android:fontFamily="@font/pretendard_regular"
            android:textSize="12sp"
            android:textColor="@color/gray2"
            android:layout_marginLeft="6dp"
            app:layout_constraintStart_toEndOf="@id/rating_bar"
            app:layout_constraintTop_toTopOf="@id/rating_bar"
            app:layout_constraintBottom_toBottomOf="@id/rating_bar"
            />

        <!--리뷰 삭제 버튼-->
        <ImageView
            android:id="@+id/btn_deleteReview"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/img_delete"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            />

        <!--상품 이미지-->
        <ImageView
            android:id="@+id/iv_productImage"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/img_product"
            android:clipToOutline="true"
            android:src="@drawable/image_product"
            android:layout_marginTop="11dp"
            app:layout_constraintTop_toBottomOf="@id/rating_bar"
            app:layout_constraintStart_toStartOf="parent"
            />

        <!--상품 브랜드-->
        <TextView
            android:id="@+id/tv_Brand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="테스트브랜드"
            android:fontFamily="@font/pretendard_light"
            android:textSize="12sp"
            android:textColor="@color/gray3"
            android:layout_marginLeft="12dp"
            app:layout_constraintStart_toEndOf="@id/iv_productImage"
            app:layout_constraintTop_toTopOf="@id/iv_productImage"
            />

        <!--상품 이름-->
        <TextView
            android:id="@+id/tv_productName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="테스트 상품명"
            android:fontFamily="@font/pretendard_medium"
            android:textSize="15sp"
            android:textColor="@color/gray1"
            android:layout_marginTop="3dp"
            app:layout_constraintStart_toStartOf="@id/tv_Brand"
            app:layout_constraintTop_toBottomOf="@id/tv_Brand"
            />

        <!--상품 리뷰-->
        <TextView
            android:id="@+id/tv_reviewText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="테스트 리뷰 내용"
            android:fontFamily="@font/pretendard_light"
            android:textSize="13sp"
            android:textColor="@color/gray2"
            android:layout_marginTop="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/iv_productImage"
            />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!--리뷰 이미지 리스트 (있을 때만 표시)-->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="13dp"
        app:layout_constraintTop_toBottomOf="@id/cl_review_card"
        android:scrollbars="none"
        >
        <!--리뷰 이미지 리스트 동적 추가-->
        <LinearLayout
            android:id="@+id/ll_review_photo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            >
        </LinearLayout>
    </HorizontalScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

